FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ─── Supabase / PostgreSQL ────────────────────────────────────────────────────
# Ve a: https://supabase.com/dashboard → tu proyecto → Settings → Database
# Copia la "Connection string" en modo "URI" y cambia [YOUR-PASSWORD]
#
# Opción A — Pooler (recomendado para producción, puerto 6543):
# DATABASE_URL=postgresql+psycopg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Opción B — Conexión directa (puerto 5432):
# DATABASE_URL=postgresql+psycopg://postgres:[password]@db.[ref].supabase.co:5432/postgres
#
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Resend API (notificaciones por correo) ───────────────────────────────────
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@tuinstitucion.edu

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
